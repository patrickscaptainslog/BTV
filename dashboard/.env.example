# AppFolio Reports API credentials
# Get from: AppFolio → Account → General Settings → Manage API Settings → Reports API Credentials
APPFOLIO_DATABASE=yourcompany          # subdomain only, e.g. "acme" from acme.appfolio.com
APPFOLIO_CLIENT_ID=your_client_id
APPFOLIO_CLIENT_SECRET=your_client_secret

# Dashboard password gate
DASHBOARD_PASSWORD=choose_a_strong_password
SESSION_SECRET=random_32_char_secret_for_cookie_signing
